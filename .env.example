# Copy to .env and fill in values: cp .env.example .env

# Django
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_NAME=arna_sso
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# JWT (RS256 PEM files; paths relative to project root or absolute)
JWT_PRIVATE_KEY_PATH=private.pem
JWT_PUBLIC_KEY_PATH=public.pem
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=5
JWT_REFRESH_TOKEN_LIFETIME_DAYS=1
PRE_AUTH_TOKEN_LIFETIME_MINUTES=5

# Email (SMTP)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=mail.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# CORS (set true only for development if needed)
CORS_ALLOW_ALL_ORIGINS=false

# WhatsApp — WAHA (push OTP)
WAHA_API_URL=
WAHA_API_KEY=

# WhatsApp — n8n reverse OTP
N8N_WEBHOOK_URL=
N8N_WEBHOOK_ID=
N8N_WEBHOOK_AUTH_TOKEN=
